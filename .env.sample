# =============================================================================
# Vernacular Artisan Catalog - Environment Configuration Sample
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.sample .env

# =============================================================================
# AWS CONFIGURATION (Optional - for full AWS deployment)
# =============================================================================

# AWS Region
AWS_REGION=ap-south-1

# AWS Account ID (your 12-digit AWS account number)
AWS_ACCOUNT_ID=your-aws-account-id

# AWS Credentials (if not using IAM roles)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# =============================================================================
# AWS SERVICES (Optional - for full AWS deployment)
# =============================================================================

# S3 Buckets for media storage
S3_RAW_MEDIA_BUCKET=artisan-catalog-raw-media
S3_ENHANCED_BUCKET=artisan-catalog-enhanced

# DynamoDB Tables
DYNAMODB_CATALOG_TABLE=CatalogProcessingRecords
DYNAMODB_TENANT_TABLE=TenantConfigurations

# SQS Queue for processing
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/your-account-id/catalog-processing-queue

# Sagemaker Endpoint (if using custom models)
SAGEMAKER_ENDPOINT_NAME=vision-asr-endpoint

# =============================================================================
# AI PROVIDERS (Required - Choose at least one)
# =============================================================================

# Groq API (Recommended - Fast and cheap)
GROQ_API_KEY=your-groq-api-key-here

# OpenAI API (Optional - Good vision quality)
# OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API (Optional - Good for cultural context)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AWS Bedrock (Optional - Requires AWS setup)
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# AI Provider Preference (groq, openai, anthropic, bedrock)
PREFERRED_AI_PROVIDER=groq

# =============================================================================
# API CONFIGURATION
# =============================================================================

# API Base URL (for mobile app integration)
API_BASE_URL=https://your-api-gateway.amazonaws.com/prod

# Server Configuration (for local/Render deployment)
PORT=8000
HOST=0.0.0.0

# =============================================================================
# ONDC INTEGRATION (Optional - for marketplace integration)
# =============================================================================

# ONDC API Configuration
ONDC_API_URL=https://staging.ondc.org/api
ONDC_SELLER_ID=your-seller-id
ONDC_API_KEY=your-ondc-api-key

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# File Upload Limits
MAX_UPLOAD_SIZE_MB=10

# Supported Languages (comma-separated language codes)
SUPPORTED_LANGUAGES=hi,te,ta,bn,mr,gu,kn,ml,pa,or

# =============================================================================
# DEVELOPMENT SETTINGS (Optional)
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug Mode (true/false)
DEBUG=false

# CORS Origins (comma-separated URLs for production)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# QUICK START GUIDE
# =============================================================================
#
# For Demo/Hackathon (Minimum required):
# 1. Get a Groq API key from: https://console.groq.com/
# 2. Set: GROQ_API_KEY=your-key-here
# 3. Set: PREFERRED_AI_PROVIDER=groq
# 4. Run: python backend/lambda_functions/api_handlers/local_demo_server.py
#
# For Full AWS Deployment:
# 1. Set up AWS credentials
# 2. Configure all AWS service settings above
# 3. Deploy using CDK or CloudFormation
#
# For Production:
# 1. Set multiple AI provider keys for fallback
# 2. Configure ONDC integration
# 3. Set appropriate CORS_ORIGINS
# 4. Use production-grade secrets management
#
# =============================================================================