# ============================================
# API Configuration for Mobile App
# ============================================

# OPTION 1: Local Development (Testing on emulator)
# API_BASE_URL=http://localhost:8000/api

# OPTION 2: Railway Deployment (Recommended for demo)
# Get this URL by running: railway domain
# API_BASE_URL=https://your-app-name.railway.app/api

# OPTION 3: Render Deployment (Free tier)
# API_BASE_URL=https://artisan-catalog-demo.onrender.com/api

# OPTION 4: AWS API Gateway (Production)
# API_BASE_URL=https://your-api-gateway.amazonaws.com/prod/api

# ============================================
# HOW TO GET YOUR API_BASE_URL:
# ============================================
# 
# See GET_API_URL_GUIDE.md for detailed instructions
#
# Quick Start:
# 1. Get free API key from https://console.anthropic.com/
# 2. Deploy to Railway:
#    npm install -g @railway/cli
#    railway login
#    railway init
#    railway variables set ANTHROPIC_API_KEY=your-key
#    railway up
#    railway domain  # This gives you your URL
# 3. Copy the URL here (add /api at the end)
# 4. Rename this file to .env
#
# ============================================

# Set your API URL here:
API_BASE_URL=http://localhost:8000/api

# ============================================
# Optional: Override specific endpoints
# ============================================
# CATALOG_GET_ENDPOINT=/v1/catalog
# CATALOG_PUBLISH_ENDPOINT=/v1/catalog/publish
# STATUS_ENDPOINT=/v1/catalog/status
