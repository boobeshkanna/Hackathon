# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id-here

# S3 Buckets
S3_RAW_MEDIA_BUCKET=artisan-catalog-raw-media
S3_ENHANCED_BUCKET=artisan-catalog-enhanced

# DynamoDB Tables
DYNAMODB_CATALOG_TABLE=CatalogProcessingRecords
DYNAMODB_TENANT_TABLE=TenantConfigurations

# SQS Queue
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/your-account/catalog-processing-queue

# Sagemaker
SAGEMAKER_ENDPOINT_NAME=vision-asr-endpoint

# Bedrock (AWS)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Third-party AI Providers (Optional - use when Bedrock unavailable)
# Set at least one for fallback support
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# AI Provider Preference (bedrock, openai, anthropic, groq)
# Leave empty for auto-detection
PREFERRED_AI_PROVIDER=

# ONDC Configuration
ONDC_API_URL=https://staging.ondc.org/api
ONDC_SELLER_ID=your-seller-id
ONDC_API_KEY=your-ondc-api-key

# Application Settings
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=10
SUPPORTED_LANGUAGES=hi,te,ta,bn,mr,gu,kn,ml,pa,or
