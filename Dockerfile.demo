# Dockerfile for Demo Server (No AWS Required)
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Install third-party AI providers
RUN pip install --no-cache-dir openai anthropic groq

# Copy application code
COPY backend/ ./backend/
COPY .env.example .env

# Expose port
EXPOSE 8000

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PORT=8000
ENV HOST=0.0.0.0

# Run demo server
CMD ["python", "backend/lambda_functions/api_handlers/local_demo_server.py"]
